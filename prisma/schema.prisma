generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model fotos_imovel {
  id         Int     @id @default(autoincrement())
  imovel_id  Int
  url_imagem String  @db.VarChar(500)
  alt_texto  String? @db.VarChar(255)
  ordem      Int?    @default(1)
  capa       Boolean @default(false)
  imoveis    imoveis @relation(fields: [imovel_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_fotos_imovel")

 
  @@index([imovel_id], map: "idx_fotos_imovel_imovel_id")
}

model imoveis {
  id           Int            @id @default(autoincrement())
  usuario_id   Int
  referencia   String         @unique(map: "referencia") @db.VarChar(100)
  tipo_negocio String         @db.VarChar(50)
  tipo_imovel  String         @db.VarChar(50)
  titulo       String         @db.VarChar(255)
  descricao    String?        @db.Text
  preco        Decimal?       @db.Decimal(15, 2)
  endereco     String?        @db.VarChar(255)
  bairro       String?        @db.VarChar(150)
  cidade       String?        @db.VarChar(150)
  estado       String?        @db.VarChar(100)
  link_mapa    String?        @db.VarChar(500)
  quartos      Int?           @default(0)
  banheiros    Int?           @default(0)
  vagas        Int?           @default(0)
  area_m2      Decimal?       @db.Decimal(10, 2)
  destaque     Boolean        @default(false)
  ativo        Boolean        @default(true)
  criado_em    DateTime       @default(now())
  fotos_imovel fotos_imovel[]
  usuarios     usuarios       @relation(fields: [usuario_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_imoveis_usuario")

  @@index([usuario_id], map: "idx_imoveis_usuario")
  @@index([ativo], map: "idx_imoveis_ativo")
  @@index([bairro], map: "idx_imoveis_bairro")
  @@index([cidade], map: "idx_imoveis_cidade")
  @@index([destaque], map: "idx_imoveis_destaque")
  @@index([estado], map: "idx_imoveis_estado")
  @@index([tipo_imovel], map: "idx_imoveis_tipo_imovel")
  @@index([tipo_negocio], map: "idx_imoveis_tipo_negocio")
}

model usuarios {
  id             Int       @id @default(autoincrement())
  nome           String    @db.VarChar(150)
  email          String    @unique(map: "email") @db.VarChar(255)
  senha          String    @db.VarChar(255)
  telefone       String?   @db.VarChar(30)
  adm            Boolean   @default(false)
  tipo_interesse String?   @db.VarChar(50)
  criado_em      DateTime  @default(now())
  imoveis        imoveis[]
}
